# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ---------------------------------------------------------------------------
# LinkedIn + hiring.cafe + Adzuna — search query
# Feeds full-text queries to LinkedIn NL, hiring.cafe, and Adzuna NL.
# Each additional query gives hiring.cafe an extra public results page (~60 results).
# ---------------------------------------------------------------------------

# Search queries (comma-separated). Broad terms work best.
# SEARCH_QUERIES=product manager,product owner,product lead,head of product

# ---------------------------------------------------------------------------
# NVB (Nationale Vacaturebank) — no API key needed
# Uses server-side taxonomy (dcoTitle) + location filters.
# ---------------------------------------------------------------------------

# NVB taxonomy title. "Productmanager" covers PM, Senior PM, Product Owner,
# Product Lead etc. per NVB's own classification.
# NVB_DCO_TITLE=Productmanager

# City for the location radius filter (coordinates resolved automatically).
# NVB_CITY=Amsterdam

# Search radius in km from the city centre (default 40).
# NVB_DISTANCE_KM=40

# ---------------------------------------------------------------------------
# Adzuna NL — API key required (free tier available)
# Register at https://developer.adzuna.com to get App ID and App Key.
# Without these, the adzuna source is silently skipped.
# ---------------------------------------------------------------------------

# ADZUNA_APP_ID=your_app_id_here
# ADZUNA_APP_KEY=your_app_key_here

# ---------------------------------------------------------------------------
# We Work Remotely (WWR) — no API key required
# Fetches the Product Jobs RSS feed. Global remote listings only.
# ---------------------------------------------------------------------------

# (Lookback window is automatic — see below.)

# ---------------------------------------------------------------------------
# Welcome to the Jungle (WTTJ) — no API key required
# Fetches global remote-friendly PM jobs (EN language) via Algolia.
# Algolia App ID and key are public/client-side and hardcoded in the fetcher.
# Covers product-management + technical-product-management professions,
# full_time/freelance/temporary contracts, remote fulltime/partial/punctual.
# ---------------------------------------------------------------------------

# (Lookback window is automatic — see below.)

# ---------------------------------------------------------------------------
# Working Nomads — no API key required
# Queries the public Elasticsearch endpoint (/jobsapi/_search).
# Category: Management (covers PM, Program Manager, Head of Product, etc.)
# Location: Europe-compatible allowlist (Anywhere, EMEA, Europe, NL, DE, UK…)
# ---------------------------------------------------------------------------

# (Lookback window is automatic — see below.)

# ---------------------------------------------------------------------------
# Lookback (automatic)
# ---------------------------------------------------------------------------
# Lookback windows are computed automatically from the gap since the last
# successful run, typically 14–30 days. There is no per-source lookback env var.

# ---------------------------------------------------------------------------
# Description enrichment (post-dedup)
# Max detail-page fetches per run, per source.
# ---------------------------------------------------------------------------

# LINKEDIN_MAX_DETAIL_FETCHES=30
# ADZUNA_MAX_DETAIL_FETCHES=50
# HIRINGCAFE_MAX_DETAIL_FETCHES=80

# ---------------------------------------------------------------------------
# Title relevance filter (applies to ALL sources)
# Only jobs whose title contains at least one of these phrases are kept.
# This is the safety net for API noise — NVB in particular returns some
# off-topic results even with the dcoTitle filter.
# Default covers: product manager, product owner, head of product, etc.
# ---------------------------------------------------------------------------
# TITLE_KEYWORDS=product manager,product owner,product lead,head of product,director of product,product director,vp product,chief product,productmanager,producteigenaar

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# SQLite DB path. Default is state.db next to this file (works on Windows).
# Override if your filesystem doesn't support SQLite file locking.
# DB_PATH=C:\Users\YourName\AppData\Local\job_scraper\state.db
