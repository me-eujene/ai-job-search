# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ---------------------------------------------------------------------------
# LinkedIn + NVB — no API key required
# LinkedIn uses the public /jobs-guest/ endpoint; NVB uses its direct API.
# ---------------------------------------------------------------------------

# Search queries for LinkedIn (comma-separated). Broad terms work best.
# SEARCH_QUERIES=product manager

# ---------------------------------------------------------------------------
# NVB (Nationale Vacaturebank) — no API key needed
# Uses server-side taxonomy (dcoTitle) + location filters.
# ---------------------------------------------------------------------------

# NVB taxonomy title. "Productmanager" covers PM, Senior PM, Product Owner,
# Product Lead etc. per NVB's own classification.
# NVB_DCO_TITLE=Productmanager

# City for the location radius filter (coordinates resolved automatically).
# NVB_CITY=Amsterdam

# Search radius in km from the city centre (default 40).
# NVB_DISTANCE_KM=40

# ---------------------------------------------------------------------------
# Adzuna NL — API key required (free tier available)
# Register at https://developer.adzuna.com to get App ID and App Key.
# Without these, the adzuna source is silently skipped.
# ---------------------------------------------------------------------------

# ADZUNA_APP_ID=your_app_id_here
# ADZUNA_APP_KEY=your_app_key_here

# Search radius in km from Amsterdam centre (default 40).
# ADZUNA_DISTANCE_KM=40

# ---------------------------------------------------------------------------
# Title relevance filter (applies to ALL sources)
# Only jobs whose title contains at least one of these phrases are kept.
# This is the safety net for API noise — NVB in particular returns some
# off-topic results even with the dcoTitle filter.
# Default covers: product manager, product owner, head of product, etc.
# ---------------------------------------------------------------------------
# TITLE_KEYWORDS=product manager,product owner,head of product,product lead,product director

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# SQLite DB path. Default is state.db next to this file (works on Windows).
# Override if your filesystem doesn't support SQLite file locking.
# DB_PATH=C:\Users\YourName\AppData\Local\job_scraper\state.db

# Web server port (default 8000).
# PORT=8000

# ---------------------------------------------------------------------------
# n8n webhook server (telegram-job-assessment addon)
# Start with: uv run python -m job_scraper.webhook_server
# ---------------------------------------------------------------------------

# Claude API key — required for the /ingest fit assessment endpoint.
# Get yours at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Claude model used for fit assessment (default: claude-sonnet-4-6).
# CLAUDE_MODEL=claude-sonnet-4-6

# Port the webhook server listens on (default: 8765).
# WEBHOOK_PORT=8765

# Bind address (default: 0.0.0.0 — all interfaces).
# WEBHOOK_HOST=0.0.0.0

# Optional shared secret between n8n and the webhook server.
# Set the same value in the n8n workflow's X-Webhook-Secret header.
# WEBHOOK_SECRET=change-me-to-a-random-string
